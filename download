function sigClass(s){return s==='buy'?'sig-buy':s==='sell'?'sig-sell':s==='watch'?'sig-watch':'sig-hold';}
function badgeClass(s){return s==='buy'?'bg-buy':s==='sell'?'bg-sell':s==='watch'?'bg-watch':s==='hold'?'bg-hold':'bg-track';}
function pnlPct(st){if(!st.pnl.entry)return null;return((st.price-st.pnl.entry)/st.pnl.entry*100).toFixed(1);}

function renderGrid(){
  renderSummary();
  const grid = document.getElementById('stock-grid');
  const filtered = filterMode==='ALL'?STOCKS:STOCKS.filter(s=>s.signal===filterMode||(filterMode==='hold'&&(s.signal==='hold'||s.action==='관망'||s.action==='보유')));
  grid.innerHTML='';
  filtered.forEach((st,fi)=>{
    const i = STOCKS.indexOf(st);
    const pnl = pnlPct(st);
    const chgPos = st.change>=0;
    const pnlPos = pnl!==null&&parseFloat(pnl)>=0;
    const hasChart = st.pnl.prices&&st.pnl.prices.length>=2;
    const div = document.createElement('div');
    div.className = `sc ${sigClass(st.signal)}${selIdx===i?' sel':''}`;
    div.onclick = ()=>selectStock(i);
    div.innerHTML=`
      <div class="sc-top">
        <div class="sc-info"><div class="sc-code">${st.ticker} · ${st.sector}</div><div class="sc-name">${st.name}</div></div>
        <span class="sc-badge ${badgeClass(st.signal)}">${st.badge}</span>
      </div>
      <div class="sc-price-row">
        <span class="sc-price">${st.price.toLocaleString()}</span>
        <span class="sc-chg ${chgPos?'pos':'neg'}">${chgPos?'+':''}${st.change}%</span>
      </div>
      <div class="sc-bottom">
        <span class="sc-sector">CMF ${st.cmf>=0?'+':''}${st.cmf} · RSI ${st.rsi}</span>
        <span class="sc-pnl ${pnl===null?'na':pnlPos?'pos':'neg'}">${pnl===null?'—':(pnlPos?'+':'')+pnl+'%'}</span>
      </div>
      ${hasChart?`<canvas class="sc-spark" id="sp${i}" height="28"></canvas>`:`<div style="height:28px;margin-top:6px;display:flex;align-items:center;font-size:9px;color:var(--tx2);">진입 대기</div>`}
    `;
    grid.appendChild(div);
    if(hasChart){
      requestAnimationFrame(()=>{
        const c = document.getElementById('sp'+i);
        if(!c)return;
