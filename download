  const nowMarker = `<div class="lvl-marker" style="left:${pct(st.price)}%;background:var(--blue);width:2px;z-index:2;"></div><div style="position:absolute;left:${pct(st.price)}%;top:-16px;font-size:9px;color:var(--blue);transform:translateX(-50%);font-weight:700;">현재</div>`;
  const stopLoss = st.pnl.entry ? Math.round(st.pnl.entry-2*st.atr).toLocaleString() : st.support[st.support.length-1].toLocaleString();
  return `<div id="tab-overview" class="dp-tab-content">
    <div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:12px;">
      <div style="font-size:20px;font-weight:700;">${st.price.toLocaleString()}<span style="font-size:12px;color:${st.change>=0?'var(--green)':'var(--red)'};margin-left:6px;">${st.change>=0?'+':''}${st.change}%</span></div>
      <div style="font-size:11px;color:var(--tx2);">ATR ${st.atr.toLocaleString()} · ADX ${st.adx}</div>
    </div>
    <div class="dp-metrics">${st.metrics.map(m=>`<div class="dm"><div class="dm-l">${m.l}</div><div class="dm-v">${m.v}</div>${m.s?`<div class="dm-s">${m.s}</div>`:''}</div>`).join('')}</div>
    <div class="verdict-box">
      <div class="dps-label">최종 트레이딩 판단</div>
      <div class="vb-action ${ac}">${st.action}${pnlDisp}</div>
      <div class="vb-reason">${st.verdict}</div>
      <div class="vb-levels">
        <div class="vbl"><span class="vbl-l">손절:</span><span class="vbl-v r">${stopLoss}원</span></div>
        <div class="vbl"><span class="vbl-l">1차저항:</span><span class="vbl-v g">${st.resist[0].toLocaleString()}원</span></div>
        <div class="vbl"><span class="vbl-l">기준선:</span><span class="vbl-v">${st.kijun.toLocaleString()}원</span></div>
      </div>
    </div>
