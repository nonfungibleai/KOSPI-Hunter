// ══════════════════════════════════════════════════════════════
// 실시간 API 연동 — 한국투자증권 모의투자 /api/price 프록시
// 매수/매도 추천가 자동 계산 포함
// ══════════════════════════════════════════════════════════════

const API_BASE   = '/api';
const REFRESH_MS = 15000;   // 장중 15초
const CLOSED_MS  = 60000;   // 장외 60초

let _liveData   = {};
let _lastFetch  = null;
let _isFetching = false;
let _timer      = null;

// ── 장 운영 시간 (KST 09:00~15:30 평일)
function isMarketOpen() {
  const kst = new Date(Date.now() + 9 * 3600000);
  if (kst.getUTCDay() === 0 || kst.getUTCDay() === 6) return false;
  const m = kst.getUTCHours() * 60 + kst.getUTCMinutes();
  return m >= 540 && m < 930;
}

// ── STOCKS 메타 정보를 API에 전달 (신호 계산용)
function buildMetaPayload() {
  const meta = {};
  STOCKS.forEach(function(st) {
    meta[st.ticker] = {
      kijun:      st.kijun      || 0,
      support:    st.support    || [],
      resist:     st.resist     || [],
      atr:        st.atr        || 0,
      rsi:        st.rsi        || 50,
      cmf:        st.cmf        || 0,
      entryPrice: st.entryPrice || 0,
    };
  });
  return encodeURIComponent(JSON.stringify(meta));
}

// ── 실시간 가격 fetch
async function fetchPrices() {
  if (_isFetching) return;
  _isFetching = true;
  setApiStatus('loading');
  try {
    const tickers = STOCKS.map(function(s){ return s.ticker; }).join(',');
    const meta    = buildMetaPayload();
    const res     = await fetch(API_BASE + '/price?tickers=' + tickers + '&meta=' + meta);

    if (!res.ok) throw new Error('HTTP ' + res.status);
    const json = await res.json();
    if (!json.ok) throw new Error(json.error || 'API 오류');

    _liveData  = json.data || {};
    _lastFetch = new Date();

    // STOCKS에 실시간 데이터 + 신호 반영
    STOCKS.forEach(function(st) {
      const d = _liveData[st.ticker];
      if (!d) return;
      st.price       = d.price;
      st.change      = parseFloat((d.change || 0).toFixed(2));
      st._live       = d;
      st._sig        = d.signal || null;   // 매수/매도 신호

      // 신호에 따라 badge/signal 자동 업데이트
      if (st._sig) {
        const a = st._sig.action;
        if      (a === 'BUY')        { st.signal = 'buy';   st.badge = '매수'; }
        else if (a === 'WATCH_BUY')  { st.signal = 'watch'; st.badge = '매수추적'; }
        else if (a === 'SELL')       { st.signal = 'sell';  st.badge = '매도'; }
        else if (a === 'WATCH_SELL') { st.signal = 'watch'; st.badge = '익절주의'; }
        else if (a === 'STOPLOSS')   { st.signal = 'sell';  st.badge = '손절!'; }
        else                         { st.signal = 'hold';  st.badge = '관망'; }
      }
    });

    setApiStatus('ok', json.mode);
    renderGrid();
    if (selIdx >= 0) refreshDetailLive(selIdx);

  } catch (e) {
    console.error('[fetchPrices]', e);
    setApiStatus('error', e.message);
  } finally {
    _isFetching = false;
  }
}

// ── 실시간 뉴스
async function loadLiveNews(st) {
  const el = document.getElementById('tab-news');
  if (!el) return;
  el.innerHTML = '<div class="dps-label" style="margin-top:4px;color:var(--tx2);">뉴스 로딩 중…</div>';
  try {
    const res  = await fetch(API_BASE + '/news?ticker=' + st.ticker);
    const json = await res.json();
    if (!json.ok || !json.data || !json.data.length) throw new Error('뉴스 없음');
    el.innerHTML =
      '<div class="dps-label" style="margin-top:4px;">실시간 뉴스 · 한투API</div>'
      + json.data.map(function(n) {
          return '<div class="news-item">'
            + '<div class="ni-date">' + n.date + ' ' + n.time + '</div>'
            + '<div class="ni-title">' + n.title + '</div>'
            + '<span class="ni-tag t-neu" style="font-size:9px;">' + n.source + '</span>'
            + '</div>';
        }).join('');
  } catch (e) {
    if (selIdx >= 0) el.innerHTML = buildNews(STOCKS[selIdx]);
  }
}

// ── 매수/매도 추천 패널 렌더링
function renderSignalPanel(st) {
  const sig = st._sig;
  const live = st._live;
  if (!sig || !live) return '';

  const actionColor = {
    BUY:        '#1fa870', WATCH_BUY:  '#3a82d4',
    SELL:       '#e04545', WATCH_SELL: '#d4820f',
    STOPLOSS:   '#e04545', HOLD:       '#5a5a60',
  }[sig.action] || '#5a5a60';

  const actionLabel = {
    BUY:        '✅ 매수 추천', WATCH_BUY:  '👀 매수 추적',
    SELL:       '🔴 매도 추천', WATCH_SELL: '⚠️ 익절 주의',
    STOPLOSS:   '🚨 손절 실행', HOLD:       '⏸ 관망',
  }[sig.action] || '관망';

  const confBar = '<div style="height:4px;background:var(--bg3);border-radius:2px;margin-top:6px;">'
    + '<div style="height:100%;width:' + sig.confidence + '%;background:' + actionColor + ';border-radius:2px;transition:width 0.5s;"></div></div>'
    + '<div style="font-size:9px;color:var(--tx2);margin-top:3px;">신뢰도 ' + sig.confidence + '%</div>';

  const priceRows = [
    { label: '📍 현재가',     val: live.price.toLocaleString() + '원',           color: '#f0eee8' },
    { label: '🟢 매수 추천가', val: sig.buyTarget ? sig.buyTarget.toLocaleString() + '원' : '-',    color: '#1fa870' },
    { label: '🎯 1차 목표가', val: sig.sellTarget1 ? sig.sellTarget1.toLocaleString() + '원' : '-', color: '#3a82d4' },
    { label: '🎯 2차 목표가', val: sig.sellTarget2 ? sig.sellTarget2.toLocaleString() + '원' : '-', color: '#d4820f' },
    { label: '🛑 손절가',     val: sig.stopLossPrice ? sig.stopLossPrice.toLocaleString() + '원' : '-', color: '#e04545' },
  ].map(function(r) {
    return '<div style="display:flex;justify-content:space-between;padding:5px 0;border-bottom:1px solid var(--bd);">'
      + '<span style="font-size:11px;color:var(--tx1);">' + r.label + '</span>'
      + '<span style="font-size:12px;font-weight:700;color:' + r.color + ';">' + r.val + '</span>'
      + '</div>';
  }).join('');

  // 수익률 표시
  const pnlRow = sig.profitPct !== null
    ? '<div style="margin-top:8px;padding:8px;background:' + (parseFloat(sig.profitPct)>=0?'rgba(31,168,112,0.1)':'rgba(224,69,69,0.1)') + ';border-radius:6px;text-align:center;">'
      + '<div style="font-size:10px;color:var(--tx2);">진입 후 현재 수익률</div>'
      + '<div style="font-size:20px;font-weight:700;color:' + (parseFloat(sig.profitPct)>=0?'#1fa870':'#e04545') + ';">'
      + (parseFloat(sig.profitPct)>=0?'+':'') + sig.profitPct + '%</div>'
      + '</div>'
    : '';

  return '<div id="tab-signal" class="dp-tab-content" style="display:none;">'
    + '<div style="border:1px solid var(--bd2);border-radius:8px;padding:14px;margin-bottom:12px;">'
    + '<div class="dps-label">퀀트 매수/매도 신호</div>'
    + '<div style="font-size:18px;font-weight:700;color:' + actionColor + ';margin-bottom:4px;">' + actionLabel + '</div>'
    + '<div style="font-size:11px;color:var(--tx1);line-height:1.6;margin-bottom:6px;">' + sig.reason + '</div>'
    + confBar
    + '</div>'
    + '<div class="dps-label">추천 가격 레벨</div>'
    + priceRows
    + pnlRow
    + '<div style="margin-top:10px;padding:8px;background:var(--bg3);border-radius:6px;font-size:10px;color:var(--tx2);line-height:1.6;">'
    + '⚡ 매수 점수 ' + sig.buyScore + '/4  ·  매도 점수 ' + sig.sellScore + '/4<br>'
    + '📊 ATR 기반 동적 손절 · 지지/저항 기반 추천가 · RSI/CMF 복합 신호'
    + '</div>'
    + '</div>';
}

// ── 상세 패널 실시간 갱신
function refreshDetailLive(i) {
  const st   = STOCKS[i];
  const live = st._live;

  // 가격
  const prEl = document.getElementById('dp-price-live');
  const chEl = document.getElementById('dp-chg-live');
  if (prEl) prEl.textContent = st.price.toLocaleString() + '원';
  if (chEl) {
    const pos = st.change >= 0;
    chEl.textContent = (pos ? '+' : '') + st.change.toFixed(2) + '%';
    chEl.style.color = pos ? '#1fa870' : '#e04545';
  }

  if (!live) return;

  // 실시간 지표
  const els = {
    vol: document.getElementById('dp-live-vol'),
    mc:  document.getElementById('dp-live-mc'),
    per: document.getElementById('dp-live-per'),
    pbr: document.getElementById('dp-live-pbr'),
    hi:  document.getElementById('dp-live-high'),
    lo:  document.getElementById('dp-live-low'),
  };
  if (els.vol) els.vol.textContent = live.volume  ? (live.volume/1000).toFixed(0)  + 'K주' : '-';
  if (els.mc)  els.mc.textContent  = live.marketCap ? live.marketCap.toLocaleString() + '억' : '-';
  if (els.per) els.per.textContent = live.per > 0 ? live.per.toFixed(1) + 'x' : '-';
  if (els.pbr) els.pbr.textContent = live.pbr > 0 ? live.pbr.toFixed(2) + 'x' : '-';
  if (els.hi)  els.hi.textContent  = live.high ? live.high.toLocaleString() + '원' : '-';
  if (els.lo)  els.lo.textContent  = live.low  ? live.low.toLocaleString()  + '원' : '-';

  // 신호 탭 갱신
  const sigTab = document.getElementById('tab-signal');
  if (sigTab && sigTab.style.display !== 'none') {
    sigTab.outerHTML = renderSignalPanel(st);
  }
}

// ── UI 상태
function setApiStatus(status, msg) {
  const dot = document.querySelector('.live-dot');
  const lbl = document.getElementById('api-status-label');
  const lst = document.getElementById('api-last-fetch');
  if (!dot || !lbl) return;
  if (status === 'ok') {
    dot.style.background = '#1fa870';
    const open = isMarketOpen();
    lbl.textContent = (msg ? '[' + msg + '] ' : '') + (open ? '● LIVE' : '● CLOSED');
    lbl.style.color  = open ? '#1fa870' : '#d4820f';
    if (lst && _lastFetch)
      lst.textContent = _lastFetch.toLocaleTimeString('ko-KR', {hour12:false}) + ' 갱신';
  } else if (status === 'loading') {
    dot.style.background = '#d4820f';
    lbl.textContent = '↻ 로딩중';
    lbl.style.color  = '#d4820f';
  } else {
    dot.style.background = '#e04545';
    lbl.textContent = '✕ API 오류';
    lbl.style.color  = '#e04545';
    if (lst) lst.textContent = (msg || '').slice(0, 60);
  }
}

// ── 자동 갱신
function startAutoRefresh() {
  fetchPrices();
  (function schedule() {
    _timer = setTimeout(function() { fetchPrices(); schedule(); },
      isMarketOpen() ? REFRESH_MS : CLOSED_MS);
  })();
}

// ── buildDetailHTML 패치: 신호 탭 추가
(function() {
  const _origBuild = buildDetailHTML;
  buildDetailHTML = function(st) {
    let html = _origBuild(st);
    // 탭 버튼에 "신호" 탭 추가
    html = html.replace(
      '<button class="dt" onclick="switchTab('pnl')">수익추적</button>',
      '<button class="dt" onclick="switchTab('pnl')">수익추적</button>'
      + '<button class="dt" onclick="switchTab('signal')" style="color:#1fa870;font-weight:600;">📊 매수/매도</button>'
    );
    // 신호 패널 삽입 (pnl 패널 뒤)
    const sigHtml = renderSignalPanel(st);
    html = html.replace('</div>
  </div>', sigHtml + '</div>
  </div>');
    return html;
  };

  // switchTab 패치: signal 탭 처리
  const _origSwitch = switchTab;
  switchTab = function(tab) {
    _origSwitch(tab);
    if (tab === 'signal') {
      document.querySelectorAll('.dp-tab-content').forEach(function(c) { c.style.display='none'; });
      const el = document.getElementById('tab-signal');
      if (el) el.style.display = 'block';
      // 탭 버튼 active 처리
      document.querySelectorAll('.dt').forEach(function(t) {
        t.classList.toggle('active', t.textContent.includes('매수/매도'));
      });
    }
    if (tab === 'news' && selIdx >= 0) loadLiveNews(STOCKS[selIdx]);
  };
})();

// ── buildOverview 패치: live 가격 ID + 실시간 지표 6개
(function() {
  const _orig = buildOverview;
  buildOverview = function(st) {
    let base = _orig(st);
    // 가격 영역 교체
    base = base.replace(
      /<div style="font-size:20px[^<]*<\/div>\s*<div style="font-size:11px[^>]*>[^<]*<\/div>/,
      '<div style="font-size:22px;font-weight:700;" id="dp-price-live">'
        + st.price.toLocaleString() + '원</div>'
        + '<div id="dp-chg-live" style="font-size:12px;margin-top:2px;color:'
        + (st.change >= 0 ? '#1fa870' : '#e04545') + ';">'
        + (st.change >= 0 ? '+' : '') + (st.change||0).toFixed(2) + '%</div>'
    );
    // 실시간 지표 6개 카드
    const liveBox =
      '<div class="dps-label" style="margin-top:10px;">실시간 시장 데이터</div>'
      + '<div class="dp-metrics">'
      + '<div class="dm"><div class="dm-l">거래량</div><div class="dm-v" id="dp-live-vol">-</div></div>'
      + '<div class="dm"><div class="dm-l">시가총액</div><div class="dm-v" id="dp-live-mc">-</div></div>'
      + '<div class="dm"><div class="dm-l">실시간 PER</div><div class="dm-v" id="dp-live-per">-</div></div>'
      + '<div class="dm"><div class="dm-l">실시간 PBR</div><div class="dm-v" id="dp-live-pbr">-</div></div>'
      + '<div class="dm"><div class="dm-l">당일 고가</div><div class="dm-v" id="dp-live-high">-</div></div>'
      + '<div class="dm"><div class="dm-l">당일 저가</div><div class="dm-v" id="dp-live-low">-</div></div>'
      + '</div>';
    base = base.replace('<div class="verdict-box"', liveBox + '<div class="verdict-box"');
    return base;
  };
})();

// ── 시작
startAutoRefresh();
</script>
