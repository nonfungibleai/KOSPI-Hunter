  const ac = {매수:'buy',매도:'sell',관망:'watch',보유:'hold',매수추적:'watch',분할매수:'buy',손절:'sell',익절:'hold'}[st.action]||'hold';
  const pnlDisp = pnl!==null?` <span style="color:${pnlPos?'var(--green)':'var(--red)'};">(${pnlPos?'+':''}${pnl}%)</span>`:'';
  const allL = [...st.support,...st.resist,st.price];
  const minL=Math.min(...allL)*0.97,maxL=Math.max(...allL)*1.03;
  const pct=v=>((v-minL)/(maxL-minL)*100).toFixed(1);
  const supMarkers = st.support.map(v=>`<div class="lvl-marker" style="left:${pct(v)}%;background:var(--red);opacity:0.8;"></div><div class="lvl-marker-label" style="left:${pct(v)}%;color:var(--red);">${(v/1000).toFixed(0)}K</div>`).join('');
