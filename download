<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>KR Quant Trading Dashboard — 실시간</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg0:#0d0d0f;--bg1:#141416;--bg2:#1a1a1d;--bg3:#222226;
  --bd:#2a2a2e;--bd2:#38383e;
  --tx0:#f0eee8;--tx1:#a8a69f;--tx2:#6a6864;
  --green:#1fa870;--green2:#0d6644;--greenbg:rgba(31,168,112,0.10);
  --red:#e04545;--red2:#8a2b2b;--redbg:rgba(224,69,69,0.10);
  --amber:#d4820f;--amberbg:rgba(212,130,15,0.10);
  --blue:#3a82d4;--bluebg:rgba(58,130,212,0.10);
  --gray:#5a5a60;--graybg:rgba(90,90,96,0.12);
  --r4:4px;--r8:8px;--r12:12px;
}
body{background:var(--bg0);color:var(--tx0);font-family:'SF Mono','Fira Mono',monospace;min-height:100vh;padding:0}

/* HEADER */
.hdr{padding:18px 24px 14px;border-bottom:1px solid var(--bd);display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:8px;position:sticky;top:0;background:rgba(13,13,15,0.96);backdrop-filter:blur(8px);z-index:100}
.hdr-left{display:flex;align-items:center;gap:14px}
.logo{font-size:11px;font-weight:600;letter-spacing:0.18em;color:var(--tx0)}
.logo span{color:var(--green)}
.live-dot{width:7px;height:7px;border-radius:50%;background:var(--green);animation:pulse 2s infinite}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:0.5;transform:scale(0.85)}}
.hdr-time{font-size:11px;color:var(--tx2);letter-spacing:0.06em}
.sess-btns{display:flex;gap:4px}
.sb{font-size:10px;padding:4px 10px;border-radius:var(--r4);border:1px solid var(--bd2);background:transparent;color:var(--tx2);cursor:pointer;letter-spacing:0.04em}
.sb.active{background:var(--greenbg);border-color:var(--green2);color:var(--green)}
.refresh-btn{font-size:10px;padding:4px 10px;border-radius:var(--r4);border:1px solid var(--bd2);background:transparent;color:var(--tx1);cursor:pointer;letter-spacing:0.04em}
.refresh-btn:hover{border-color:var(--green2);color:var(--green)}

/* FILTER BAR */
.filter-bar{padding:10px 24px;border-bottom:1px solid var(--bd);display:flex;gap:6px;flex-wrap:wrap;align-items:center}
.fb-label{font-size:10px;color:var(--tx2);letter-spacing:0.06em;margin-right:4px}
.fb-btn{font-size:10px;padding:3px 10px;border-radius:var(--r4);border:1px solid var(--bd);background:transparent;color:var(--tx2);cursor:pointer}
.fb-btn.active{background:var(--bg3);color:var(--tx0);border-color:var(--bd2)}
.fb-btn.f-buy.active{background:var(--greenbg);border-color:var(--green2);color:var(--green)}
.fb-btn.f-sell.active{background:var(--redbg);border-color:var(--red2);color:var(--red)}
.fb-btn.f-watch.active{background:var(--amberbg);border-color:var(--amber);color:var(--amber)}

/* SUMMARY STRIP */
.summary-strip{padding:10px 24px;border-bottom:1px solid var(--bd);display:flex;gap:20px;flex-wrap:wrap}
.ss-item{display:flex;flex-direction:column;gap:2px}
.ss-label{font-size:9px;color:var(--tx2);letter-spacing:0.07em}
.ss-val{font-size:13px;font-weight:600;letter-spacing:0.02em}
.ss-val.g{color:var(--green)}.ss-val.r{color:var(--red)}.ss-val.a{color:var(--amber)}

/* MAIN LAYOUT */
.main{display:grid;grid-template-columns:1fr 380px;min-height:calc(100vh - 120px)}
@media(max-width:900px){.main{grid-template-columns:1fr}}

/* GRID PANEL */
.grid-panel{padding:16px 24px;border-right:1px solid var(--bd);overflow-y:auto}
.gp-label{font-size:9px;color:var(--tx2);letter-spacing:0.10em;margin-bottom:10px}
.stock-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:8px}

/* STOCK CARD */
.sc{background:var(--bg1);border:1px solid var(--bd);border-radius:var(--r8);padding:12px;cursor:pointer;transition:border-color 0.12s,background 0.12s;position:relative;overflow:hidden}
.sc:hover{border-color:var(--bd2);background:var(--bg2)}
.sc.sel{border-color:var(--blue);background:var(--bg2)}
.sc::before{content:'';position:absolute;left:0;top:0;bottom:0;width:2px}
.sc.sig-buy::before{background:var(--green)}
.sc.sig-sell::before{background:var(--red)}
.sc.sig-watch::before{background:var(--amber)}
.sc.sig-hold::before{background:var(--gray)}
.sc-top{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:6px}
.sc-info .sc-code{font-size:9px;color:var(--tx2);letter-spacing:0.06em;margin-bottom:1px}
.sc-info .sc-name{font-size:12px;font-weight:600;color:var(--tx0);line-height:1.25}
.sc-badge{font-size:9px;font-weight:600;padding:2px 7px;border-radius:3px;letter-spacing:0.04em;white-space:nowrap}
.bg-buy{background:var(--greenbg);color:var(--green);border:1px solid var(--green2)}
.bg-sell{background:var(--redbg);color:var(--red);border:1px solid var(--red2)}
.bg-watch{background:var(--amberbg);color:var(--amber);border:1px solid #6b4108}
.bg-hold{background:var(--graybg);color:#888;border:1px solid #444}
.bg-track{background:var(--bluebg);color:var(--blue);border:1px solid #1e4d8a}
.sc-price-row{display:flex;align-items:baseline;gap:6px;margin-bottom:4px}
.sc-price{font-size:16px;font-weight:600;letter-spacing:-0.01em}
.sc-chg{font-size:11px;font-weight:500}
.sc-chg.pos{color:var(--green)}.sc-chg.neg{color:var(--red)}
.sc-bottom{display:flex;justify-content:space-between;align-items:center}
.sc-sector{font-size:9px;color:var(--tx2)}
.sc-pnl{font-size:11px;font-weight:600}
.sc-pnl.pos{color:var(--green)}.sc-pnl.neg{color:var(--red)}.sc-pnl.na{color:var(--tx2)}
.sc-spark{width:100%;height:28px;margin-top:6px}

/* DETAIL PANEL */
.detail-panel{background:var(--bg1);overflow-y:auto;position:sticky;top:56px;height:calc(100vh - 56px)}
.detail-panel.empty{display:flex;align-items:center;justify-content:center}
.dp-placeholder{text-align:center;color:var(--tx2);font-size:11px;line-height:2}
.dp-inner{padding:0}
.dp-hdr{padding:14px 16px 0;border-bottom:1px solid var(--bd)}
.dp-close{float:right;font-size:10px;color:var(--tx2);cursor:pointer;border:1px solid var(--bd);background:transparent;border-radius:3px;padding:2px 7px;margin-top:2px}
.dp-title{font-size:14px;font-weight:600;color:var(--tx0);margin-bottom:2px}
.dp-sub{font-size:10px;color:var(--tx2);margin-bottom:10px}
.dp-tabs{display:flex;gap:2px;padding:8px 16px 0;border-bottom:1px solid var(--bd)}
.dt{font-size:10px;padding:5px 10px;border-radius:var(--r4) var(--r4) 0 0;cursor:pointer;color:var(--tx2);background:transparent;border:none;border-bottom:2px solid transparent;letter-spacing:0.04em}
.dt.active{color:var(--tx0);border-bottom-color:var(--green)}
.dp-body{padding:14px 16px}
.dp-section{margin-bottom:14px}
.dps-label{font-size:9px;color:var(--tx2);letter-spacing:0.08em;margin-bottom:6px}

/* VERDICT */
.verdict-box{border:1px solid var(--bd2);border-radius:var(--r8);padding:12px;margin-bottom:12px}
.vb-action{font-size:16px;font-weight:700;margin-bottom:4px}
.vb-action.buy{color:var(--green)}.vb-action.sell{color:var(--red)}.vb-action.watch{color:var(--amber)}.vb-action.hold{color:var(--gray)}
.vb-reason{font-size:11px;color:var(--tx1);line-height:1.6}
.vb-levels{display:flex;gap:10px;margin-top:8px;flex-wrap:wrap}
.vbl{font-size:10px}.vbl-l{color:var(--tx2)}.vbl-v{font-weight:600;margin-left:3px}
.vbl-v.r{color:var(--red)}.vbl-v.g{color:var(--green)}

/* METRICS */
.dp-metrics{display:grid;grid-template-columns:1fr 1fr;gap:6px;margin-bottom:12px}
.dm{background:var(--bg2);border-radius:var(--r4);padding:8px 10px}
.dm-l{font-size:9px;color:var(--tx2);letter-spacing:0.04em;margin-bottom:3px}
.dm-v{font-size:13px;font-weight:600;color:var(--tx0)}
.dm-s{font-size:9px;color:var(--tx2);margin-top:1px}

/* INDICATORS TABLE */
.ind-tbl{width:100%;border-collapse:collapse;font-size:11px}
.ind-tbl th{font-size:9px;color:var(--tx2);text-align:left;padding:3px 6px 5px;border-bottom:1px solid var(--bd);letter-spacing:0.05em;font-weight:400}
.ind-tbl td{padding:5px 6px;border-bottom:1px solid var(--bd);vertical-align:middle;color:var(--tx0)}
.ind-tbl tr:last-child td{border-bottom:none}
.bar-w{width:60px;height:4px;background:var(--bg3);border-radius:2px;display:inline-block;vertical-align:middle;margin-left:4px}
.bar-f{height:100%;border-radius:2px}
.bf-g{background:var(--green)}.bf-r{background:var(--red)}.bf-n{background:var(--gray)}

/* NEWS */
.news-item{padding:8px 0;border-bottom:1px solid var(--bd)}
.news-item:last-child{border-bottom:none}
.ni-date{font-size:9px;color:var(--tx2);margin-bottom:2px}
.ni-title{font-size:11px;color:var(--tx0);line-height:1.4;margin-bottom:3px}
.ni-tag{font-size:9px;padding:1px 5px;border-radius:2px}
.t-pos{background:var(--greenbg);color:var(--green)}.t-neg{background:var(--redbg);color:var(--red)}.t-neu{background:var(--graybg);color:#888}

/* CONSENSUS TABLE */
.cons-tbl{width:100%;border-collapse:collapse;font-size:11px}
.cons-tbl th{font-size:9px;color:var(--tx2);text-align:right;padding:3px 6px 5px;border-bottom:1px solid var(--bd);letter-spacing:0.04em;font-weight:400}
.cons-tbl th:first-child{text-align:left}
.cons-tbl td{padding:5px 6px;border-bottom:1px solid var(--bd);text-align:right}
.cons-tbl td:first-child{text-align:left;color:var(--tx2)}
.cons-tbl tr:last-child td{border-bottom:none}
.cu{color:var(--green)}.cd{color:var(--red)}

/* PNL */
.pnl-wrap{height:120px;position:relative;margin-bottom:8px}
.pnl-label{font-size:10px;color:var(--tx2);text-align:center}

/* LEVEL BAR */
.lvl-bar{position:relative;height:24px;background:var(--bg3);border-radius:3px;margin-bottom:20px}
.lvl-marker{position:absolute;top:0;bottom:0;width:1px}
.lvl-marker-label{position:absolute;top:26px;font-size:9px;transform:translateX(-50%);white-space:nowrap}

/* CHART HEIGHT */
.ch-wrap{height:140px;position:relative;margin-top:10px}

/* SCROLLBAR */
::-webkit-scrollbar{width:4px;height:4px}
::-webkit-scrollbar-track{background:var(--bg0)}
::-webkit-scrollbar-thumb{background:var(--bd2);border-radius:2px}

@media(max-width:900px){
  .detail-panel{position:relative;height:auto;border-top:1px solid var(--bd)}
  .main{grid-template-columns:1fr}
  .grid-panel{border-right:none}
}
</style>
</head>
