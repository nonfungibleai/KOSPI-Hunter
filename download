function renderSummary(){
  const buyCount = STOCKS.filter(s=>s.signal==='buy').length;
  const watchCount = STOCKS.filter(s=>s.signal==='watch').length;
  const posStocks = STOCKS.filter(s=>s.pnl.entry&&s.price>s.pnl.entry);
  const avgPnl = STOCKS.filter(s=>s.pnl.entry).map(s=>((s.price-s.pnl.entry)/s.pnl.entry*100));
  const mean = avgPnl.length ? (avgPnl.reduce((a,b)=>a+b,0)/avgPnl.length).toFixed(1) : '-';
  const meanClass = parseFloat(mean)>=0?'g':'r';
  document.getElementById('summary-strip').innerHTML = `
    <div class="ss-item"><div class="ss-label">전체 종목</div><div class="ss-val">${STOCKS.length}</div></div>
    <div class="ss-item"><div class="ss-label">매수 신호</div><div class="ss-val g">${buyCount}</div></div>
    <div class="ss-item"><div class="ss-label">매수 추적</div><div class="ss-val a">${watchCount}</div></div>
    <div class="ss-item"><div class="ss-label">진입 종목</div><div class="ss-val">${STOCKS.filter(s=>s.pnl.entry).length}</div></div>
    <div class="ss-item"><div class="ss-label">평균 수익률</div><div class="ss-val ${meanClass}">${mean!=='-'?(parseFloat(mean)>=0?'+':'')+mean+'%':'-'}</div></div>
