// ============================================================
// STATE
// ============================================================
let filterMode = 'ALL';
let editIdx = -1;
 
// ============================================================
// RENDER
// ============================================================
function pnlPct(d){
  if(!d.entryPrice)return null;
  return((d.price-d.entryPrice)/d.entryPrice*100).toFixed(1);
}
 
function renderSummary(){
  const buyN = DATA.filter(d=>d.signal==='buy').length;
  const watchN = DATA.filter(d=>d.signal==='watch').length;
  const entN = DATA.filter(d=>d.entryPrice).length;
  const pnls = DATA.filter(d=>d.entryPrice).map(d=>parseFloat(pnlPct(d)));
  const avg = pnls.length?(pnls.reduce((a,b)=>a+b,0)/pnls.length).toFixed(1):null;
  const posN = pnls.filter(p=>p>=0).length;
  document.getElementById('summary-row').innerHTML=`
    <div class="sr-item"><span class="sr-l">전체</span><span class="sr-v">${DATA.length}종목</span></div>
    <div class="sr-item"><span class="sr-l">매수신호</span><span class="sr-v g">${buyN}</span></div>
    <div class="sr-item"><span class="sr-l">매수추적</span><span class="sr-v a">${watchN}</span></div>
    <div class="sr-item"><span class="sr-l">진입완료</span><span class="sr-v">${entN}</span></div>
    <div class="sr-item"><span class="sr-l">평균수익률</span><span class="sr-v ${avg&&parseFloat(avg)>=0?'g':'r'}">${avg?(parseFloat(avg)>=0?'+':'')+avg+'%':'—'}</span></div>
    <div class="sr-item"><span class="sr-l">수익종목</span><span class="sr-v g">${posN}개</span></div>
    <div class="sr-item"><span class="sr-l">손실종목</span><span class="sr-v r">${pnls.length-posN}개</span></div>
  `;
}
 
function renderTable(){
  renderSummary();
  const tbody = document.getElementById('tbl-body');
  const filtered = filterMode==='ALL'?DATA:DATA.filter(d=>d.signal===filterMode);
  tbody.innerHTML = '';
  filtered.forEach((d,fi)=>{
    const i = DATA.indexOf(d);
    const pnl = pnlPct(d);
    const pnlPos = pnl!==null&&parseFloat(pnl)>=0;
    const rowClass = d.signal==='buy'?'row-buy':d.signal==='watch'?'row-watch':'row-hold';
    const badgeCls = d.signal==='buy'?'sb-buy':d.signal==='watch'?'sb-watch':d.signal==='hold'?'sb-hold':'sb-sell';
    const cmfCls = d.cmf>0.05?'ip-bull':d.cmf<-0.05?'ip-bear':'ip-neutral';
    const rsiCls = d.rsi>65?'ip-bear':d.rsi<35?'ip-bull':'ip-neutral';
    const adxCls = d.adx>25?'ip-bull':'ip-neutral';
    const sup = d.support.map(v=>v.toLocaleString()).join(' / ');
    const res = d.resist.slice(0,2).map(v=>v.toLocaleString()).join(' / ');
    const buyCrit = d.buyConditions.map((c,ci)=>`<div class="crit-item buy-crit"><span class="crit-num">${ci+1}</span><span class="crit-txt">${c}</span></div>`).join('');
    const sellCrit = d.sellConditions.map((c,ci)=>`<div class="crit-item sell-crit"><span class="crit-num">${ci+1}</span><span class="crit-txt">${c}</span></div>`).join('');
    const e26c = d.eps26F.includes('+')?'eps-up':d.eps26F.includes('-')||d.eps26F.includes('적')?'eps-dn':'';
    const e27c = d.eps27F.includes('+')?'eps-up':d.eps27F.includes('-')||d.eps27F.includes('적')?'eps-dn':'';
 
    const tr = document.createElement('tr');
    tr.className = rowClass;
    tr.style.cursor='pointer';
    tr.onclick = ()=>openEdit(i);
    tr.innerHTML=`
      <td class="cell-name"><div class="cn-name">${d.name}</div><div class="cn-code">${d.ticker}</div><div class="cn-sector">${d.sector}</div></td>
      <td class="center"><span class="signal-badge ${badgeCls}">${d.badge}</span></td>
      <td><strong>${d.price.toLocaleString()}</strong><br><span style="font-size:10px;color:${d.change>=0?'var(--green)':'var(--red)'};">${d.change>=0?'+':''}${d.change}%</span></td>
      <td class="pnl-cell ${pnl===null?'pnl-na':pnlPos?'pnl-pos':'pnl-neg'}">${pnl===null?'—':(pnlPos?'+':'')+pnl+'%'}<br><span style="font-size:9px;color:var(--tx2);font-weight:400;">${d.entryPrice?d.entryPrice.toLocaleString()+'원':'미진입'}</span></td>
      <td>
        <span class="ind-pill ${cmfCls}">CMF ${d.cmf>=0?'+':''}${d.cmf}</span>
        <span class="ind-pill ${rsiCls}">RSI ${d.rsi}</span>
        <span class="ind-pill ${adxCls}">ADX ${d.adx}</span>
      </td>
      <td><div class="buy-crit">${buyCrit}</div></td>
      <td><div class="sell-crit">${sellCrit}</div></td>
      <td class="level-cell">
        <span class="lv-label">지지</span><span class="lv-sup">${sup}</span><br>
        <span class="lv-label">저항</span><span class="lv-res">${res}</span>
      </td>
      <td class="eps-cell">
        <span class="lv-label">26F</span><span class="${e26c}">${d.eps26F}</span><br>
        <span class="lv-label">27F</span><span class="${e27c}">${d.eps27F}</span>
      </td>
      <td style="font-size:11px;font-weight:600;">${d.targetPrice}원</td>
      <td class="note-cell">${d.note}</td>
    `;
    tbody.appendChild(tr);
  });
}
 
function filterRows(f, btn){
  filterMode=f;
  document.querySelectorAll('.tag').forEach(t=>t.classList.remove('active'));
  btn.classList.add('active');
  renderTable();
}
 
// ============================================================
// EDIT MODAL
// ============================================================
function openEdit(i){
  editIdx=i;
  const d=DATA[i];
  document.getElementById('modal-title').textContent=`수정: ${d.name} (${d.ticker})`;
  document.getElementById('f-price').value=d.price;
  document.getElementById('f-change').value=d.change;
  document.getElementById('f-signal').value=d.signal;
  document.getElementById('f-badge').value=d.badge;
  document.getElementById('f-rsi').value=d.rsi;
  document.getElementById('f-cmf').value=d.cmf;
  document.getElementById('f-atr').value=d.atr;
  document.getElementById('f-adx').value=d.adx;
  document.getElementById('f-entry').value=d.entryPrice||'';
  document.getElementById('f-edate').value=d.entryDate||'';
  document.getElementById('f-verdict').value=d.verdict||'';
  document.getElementById('f-note').value=d.note||'';
  document.getElementById('modal').classList.add('open');
}
 
function closeModal(){document.getElementById('modal').classList.remove('open');editIdx=-1;}
 
function saveEdit(){
  if(editIdx<0)return;
  const d=DATA[editIdx];
  d.price=parseInt(document.getElementById('f-price').value)||d.price;
  d.change=parseFloat(document.getElementById('f-change').value)||d.change;
  d.signal=document.getElementById('f-signal').value;
  d.badge=document.getElementById('f-badge').value||d.badge;
  d.rsi=parseFloat(document.getElementById('f-rsi').value)||d.rsi;
  d.cmf=parseFloat(document.getElementById('f-cmf').value);
  d.atr=parseInt(document.getElementById('f-atr').value)||d.atr;
  d.adx=parseInt(document.getElementById('f-adx').value)||d.adx;
  d.entryPrice=parseInt(document.getElementById('f-entry').value)||null;
  d.entryDate=document.getElementById('f-edate').value||null;
  d.note=document.getElementById('f-note').value;
  closeModal();
  renderTable();
}
 
// ============================================================
// CSV EXPORT
// ============================================================
function exportCSV(){
  const headers=['종목명','티커','섹터','신호','현재가','등락률','수익률','RSI','CMF','ATR','ADX','매수진입가','진입일','지지선','저항선','EPS26F','EPS27F','목표주가','특이사항'];
  const rows=DATA.map(d=>{
    const pnl=pnlPct(d);
    return [
      d.name,d.ticker,d.sector,d.badge,d.price,d.change+'%',
      pnl?pnl+'%':'미진입',d.rsi,d.cmf,d.atr,d.adx,
      d.entryPrice||'',d.entryDate||'',
      d.support.join('/'),d.resist.join('/'),
      d.eps26F,d.eps27F,d.targetPrice,
      '"'+d.note.replace(/"/g,"'")+'"'
    ].join(',');
  });
  const csv='\uFEFF'+[headers.join(','),...rows].join('\n');
  const a=document.createElement('a');
  a.href='data:text/csv;charset=utf-8,'+encodeURIComponent(csv);
  a.download='kr_trading_strategy_'+new Date().toISOString().slice(0,10)+'.csv';
  a.click();
}
 
// INIT
renderTable();
</script>
